{
  "name": "http-client",
  "version": "1.0.0",
  "description": "Http Client",
  "keywords": [
    "Http",
    "Client"
  ],
  "homepage": "https://github.com/Dmn117/HttpClient#readme",
  "bugs": {
    "url": "https://github.com/Dmn117/HttpClient/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Dmn117/HttpClient.git"
  },
  "license": "MIT",
  "author": "Juan Manuel Romero Proa",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "test": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
